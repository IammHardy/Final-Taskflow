<div style="max-width:560px;margin:0 auto">
  <div class="page-header">
    <h1 class="page-title">Edit Company</h1>
    <%= link_to "← Back", admin_companies_path, class: "btn-secondary" %>
  </div>
  <div class="card">
    <%= form_with model: [:admin, @company] do |f| %>
      <% if @company.errors.any? %>
        <div class="flash-alert"><%= @company.errors.full_messages.first %></div>
      <% end %>
      <div class="form-group">
        <%= f.label :name, class: "label" %>
        <%= f.text_field :name, class: "input" %>
      </div>
      <div class="form-group">
        <%= f.label :industry, class: "label" %>
        <%= f.text_field :industry, class: "input" %>
      </div>
      <div class="form-group">
        <%= f.label :plan, class: "label" %>
        <%= f.select :plan, Company.plans.keys.map { |p| [p.humanize, p] }, {}, class: "input" %>
      </div>
      <div class="form-group" style="display:flex;align-items:center;gap:0.5rem">
        <%= f.check_box :active %>
        <%= f.label :active, "Active", style: "margin:0;font-weight:500" %>
      </div>
      <div style="display:flex;gap:0.75rem;margin-top:1.5rem">
        <%= f.submit "Save Changes", class: "btn-primary" %>
        <%= link_to "Cancel", admin_companies_path, class: "btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>