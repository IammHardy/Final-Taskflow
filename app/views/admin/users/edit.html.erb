<div style="max-width:560px;margin:0 auto">
  <div class="page-header">
    <h1 class="page-title">Edit User</h1>
    <%= link_to "← Back", admin_users_path, class: "btn-secondary" %>
  </div>
  <div class="card">
    <%= form_with model: [:admin, @user] do |f| %>
      <% if @user.errors.any? %>
        <div class="flash-alert"><%= @user.errors.full_messages.first %></div>
      <% end %>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
        <div class="form-group">
          <%= f.label :first_name, class: "label" %>
          <%= f.text_field :first_name, class: "input" %>
        </div>
        <div class="form-group">
          <%= f.label :last_name, class: "label" %>
          <%= f.text_field :last_name, class: "input" %>
        </div>
      </div>
      <div class="form-group">
        <%= f.label :email, class: "label" %>
        <%= f.email_field :email, class: "input" %>
      </div>
      <div class="form-group">
        <%= f.label :role, class: "label" %>
        <%= f.select :role, User.roles.keys.map { |r| [r.humanize, r] }, {}, class: "input" %>
      </div>
      <div class="form-group">
        <%= f.label :company_id, "Company", class: "label" %>
        <%= f.collection_select :company_id, Company.all, :id, :name,
            { include_blank: "— No company —" }, { class: "input" } %>
      </div>
      <div class="form-group">
        <%= f.label :sector_id, "Sector", class: "label" %>
        <%= f.collection_select :sector_id, Sector.all, :id, :name,
            { include_blank: "— No sector —" }, { class: "input" } %>
      </div>
      <div class="form-group" style="display:flex;align-items:center;gap:0.5rem">
        <%= f.check_box :active %>
        <%= f.label :active, "Active account", style: "margin:0;font-weight:500" %>
      </div>
      <div style="display:flex;gap:0.75rem;margin-top:1.5rem">
        <%= f.submit "Save Changes", class: "btn-primary" %>
        <%= link_to "Cancel", admin_users_path, class: "btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>