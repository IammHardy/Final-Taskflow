<div style="max-width:640px;margin:0 auto">
  <div class="page-header">
    <div>
      <h1 class="page-title">New User</h1>
      <p class="page-subtitle">Create a user and assign them to a company</p>
    </div>
    <%= link_to "← Back", admin_users_path, class: "btn-secondary" %>
  </div>

  <div class="card">
    <%= form_with model: [:admin, @user], local: true do |f| %>
      <% if @user.errors.any? %>
        <div class="flash-alert" style="margin-bottom:1.25rem">
          <%= @user.errors.full_messages.first %>
        </div>
      <% end %>

      <p style="font-size:0.75rem;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:1rem">Personal Info</p>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
        <div class="form-group">
          <%= f.label :first_name, class: "label" %>
          <%= f.text_field :first_name, class: "input", placeholder: "John" %>
        </div>
        <div class="form-group">
          <%= f.label :last_name, class: "label" %>
          <%= f.text_field :last_name, class: "input", placeholder: "Doe" %>
        </div>
      </div>

      <div class="form-group">
        <%= f.label :email, class: "label" %>
        <%= f.email_field :email, class: "input", placeholder: "john@company.com" %>
      </div>

      <div class="form-group">
        <%= f.label :phone, class: "label" %>
        <%= f.text_field :phone, class: "input", placeholder: "+1 555 000 0000" %>
      </div>

      <div style="height:1px;background:#f3f4f6;margin:1.25rem 0"></div>
      <p style="font-size:0.75rem;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:1rem">Assignment</p>

      <div class="form-group">
        <%= f.label :company_id, "Company", class: "label" %>
        <%= f.collection_select :company_id, Company.all.order(:name), :id, :name,
            { include_blank: "— Select company —", selected: params[:company_id] },
            { class: "input", id: "user_company_id" } %>
      </div>

      <div class="form-group">
        <%= f.label :sector_id, "Sector", class: "label" %>
        <%= f.collection_select :sector_id, Sector.all.order(:name), :id, :name,
            { include_blank: "— Select sector —" },
            { class: "input", id: "user_sector_id" } %>
        <p style="font-size:0.75rem;color:#9ca3af;margin-top:0.25rem">Select company first, then sector</p>
      </div>

      <div class="form-group">
        <%= f.label :role, class: "label" %>
        <%= f.select :role,
            User.roles.keys.map { |r| [r.humanize, r] },
            { selected: "employee" }, { class: "input" } %>
      </div>

      <div style="height:1px;background:#f3f4f6;margin:1.25rem 0"></div>
      <p style="font-size:0.75rem;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.25rem">Password</p>
      <p style="font-size:0.8rem;color:#9ca3af;margin-bottom:1rem">Leave blank to auto-generate. It will be shown after creation.</p>

      <div class="form-group">
        <%= f.label :password, class: "label" %>
        <%= f.password_field :password, class: "input",
            placeholder: "Leave blank to auto-generate",
            autocomplete: "new-password" %>
      </div>

      <div style="display:flex;gap:0.75rem;margin-top:1.5rem">
        <%= f.submit "Create User", class: "btn-primary" %>
        <%= link_to "Cancel", admin_users_path, class: "btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>