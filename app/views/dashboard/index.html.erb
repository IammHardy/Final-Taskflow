<div class="page-header">
  <div>
    <h1 class="page-title">Good <%= greeting %>, <%= current_user.first_name %> 👋</h1>
    <p class="page-subtitle"><%= Date.today.strftime("%A, %B %-d, %Y") %> · <%= current_user.company.name %></p>
  </div>
  <%= link_to new_task_path, class: "btn-primary" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    New Task
  <% end %>
</div>

<!-- Stats row -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <%= render "dashboard/stat_card", value: @stats[:total_tasks],    label: "Total Tasks",    icon: "📋", color: "brand" %>
  <%= render "dashboard/stat_card", value: @stats[:my_tasks],       label: "Assigned to me", icon: "👤", color: "blue" %>
  <%= render "dashboard/stat_card", value: @stats[:overdue],        label: "Overdue",        icon: "⚠️", color: "red" %>
  <%= render "dashboard/stat_card", value: @stats[:done_this_week], label: "Done this week", icon: "✅", color: "green" %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- My tasks -->
  <div class="lg:col-span-2">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-base font-semibold text-gray-900">My Tasks</h2>
      <%= link_to tasks_path, class: "text-sm text-brand-600 hover:text-brand-700 font-medium" do %>View all →<% end %>
    </div>
    <div class="space-y-2">
      <% if @my_tasks.any? %>
        <% @my_tasks.each do |task| %>
          <%= render "tasks/task_row", task: task %>
        <% end %>
      <% else %>
        <div class="card text-center py-10">
          <p class="text-gray-400 text-sm">No tasks assigned to you yet 🎉</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Sidebar: AI summary + recent -->
  <div class="space-y-6">
    <% if @ai_summary %>
      <div class="card border-l-4 border-brand-400">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-base">🤖</span>
          <h3 class="text-sm font-semibold text-gray-900">AI Summary</h3>
          <span class="badge-purple ml-auto text-xs">AI</span>
        </div>
        <p class="text-sm text-gray-600 leading-relaxed"><%= @ai_summary["summary"] %></p>
        <% if @ai_summary["key_alerts"]&.any? %>
          <ul class="mt-3 space-y-1">
            <% @ai_summary["key_alerts"].each do |alert| %>
              <li class="flex items-start gap-2 text-xs text-orange-700">
                <span>⚡</span><span><%= alert %></span>
              </li>
            <% end %>
          </ul>
        <% end %>
      </div>
    <% end %>

    <div>
      <h2 class="text-base font-semibold text-gray-900 mb-4">Recent Activity</h2>
      <div class="space-y-2">
        <% @recent_tasks.each do |task| %>
          <div class="card-sm flex items-center gap-3">
            <%= status_badge(task.status) %>
            <span class="text-sm text-gray-700 truncate flex-1"><%= task.title %></span>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>