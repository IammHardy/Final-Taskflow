<div class="min-h-screen bg-gradient-to-br from-indigo-50 via-white to-purple-50 flex items-center justify-center p-4">
  <div style="width:100%;max-width:420px">

    <!-- Logo -->
    <div style="text-align:center;margin-bottom:2rem">
      <div style="width:3rem;height:3rem;background:#6366f1;border-radius:0.75rem;display:inline-flex;align-items:center;justify-content:center;margin-bottom:1rem">
        <svg style="width:1.5rem;height:1.5rem;color:white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
        </svg>
      </div>
      <h1 style="font-size:1.5rem;font-weight:700;color:#111827">Welcome back</h1>
      <p style="color:#6b7280;font-size:0.875rem;margin-top:0.25rem">Sign in to your TaskFlow account</p>
    </div>

    <!-- Card -->
    <div class="card">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

        <% if alert.present? %>
          <div class="flash-alert"><%= alert %></div>
        <% end %>

        <div class="form-group">
          <%= f.label :email, class: "label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input", placeholder: "you@company.com" %>
        </div>

        <div class="form-group">
          <%= f.label :password, class: "label" %>
          <%= f.password_field :password, autocomplete: "current-password", class: "input", placeholder: "••••••••" %>
        </div>

        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem">
          <label style="display:flex;align-items:center;gap:0.5rem;font-size:0.875rem;color:#374151">
            <%= f.check_box :remember_me %>
            Remember me
          </label>
          <%= link_to "Forgot password?", new_password_path(resource_name), style: "font-size:0.875rem;color:#6366f1;text-decoration:none" %>
        </div>

        <%= f.submit "Sign in", class: "btn-primary", style: "width:100%;justify-content:center" %>

      <% end %>
    </div>

    <p style="text-align:center;margin-top:1.5rem;font-size:0.875rem;color:#6b7280">
      Don't have an account?
      <%= link_to "Contact your administrator", "#", style: "color:#6366f1;font-weight:500;text-decoration:none" %>
    </p>

  </div>
</div>