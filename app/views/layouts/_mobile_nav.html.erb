<details class="lg:hidden sticky top-0 z-50 bg-white border-b border-gray-100 group">
  <summary class="list-none flex items-center justify-between px-4 py-3 cursor-pointer">
    <div class="flex items-center gap-2.5 min-w-0">
      <div class="w-8 h-8 rounded-lg bg-brand-500 flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
        </svg>
      </div>

      <div class="min-w-0">
        <p class="text-sm font-bold text-gray-900">TaskFlow</p>
        <p class="text-xs text-gray-400 truncate">
          <%= current_user.super_admin? ? "System Admin" : current_user.company&.name %>
        </p>
      </div>
    </div>

    <div class="text-gray-600">
      <svg class="h-5 w-5 group-open:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg class="h-5 w-5 hidden group-open:block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </div>
  </summary>

  <div class="border-t border-gray-100 bg-white">
    <nav class="px-3 py-3 space-y-1">
      <%= render "layouts/nav_item", path: dashboard_index_path, icon: "home", label: "Dashboard" %>
      <%= render "layouts/nav_item", path: tasks_path, icon: "tasks", label: "Tasks" %>

      <% if current_user.manager_or_above? %>
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider px-3 pt-4 pb-2">Manage</p>
        <%= render "layouts/nav_item", path: "/team", icon: "users", label: "Team" %>
        <%= render "layouts/nav_item", path: sectors_path, icon: "sectors", label: "Sectors" %>
      <% end %>

      <% if current_user.admin_or_above? %>
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider px-3 pt-4 pb-2">Admin</p>
        <%= render "layouts/nav_item", path: admin_root_path, icon: "settings", label: "Admin Panel" %>
      <% end %>
    </nav>

    <div class="border-t border-gray-100 px-3 py-3">
      <%= link_to profile_path, class: "flex items-center gap-3 rounded-lg px-3 py-2 hover:bg-gray-50" do %>
        <div class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-brand-100 text-brand-700 text-xs font-semibold">
          <%= current_user.initials %>
        </div>
        <div class="min-w-0 flex-1">
          <p class="text-sm font-medium text-gray-900 truncate"><%= current_user.full_name %></p>
          <p class="text-xs text-gray-400"><%= current_user.role.humanize %></p>
        </div>
      <% end %>

      <div class="mt-2">
        <%= button_to "Sign out",
                      destroy_user_session_path,
                      method: :delete,
                      form: { class: "w-full" },
                      class: "w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-left text-sm font-medium text-gray-700" %>
      </div>
    </div>
  </div>
</details>