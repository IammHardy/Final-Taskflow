<aside class="sidebar">
  <!-- Logo -->
  <div class="flex items-center gap-2.5 px-5 py-5 border-b border-gray-100">
    <div class="w-8 h-8 rounded-lg bg-brand-500 flex items-center justify-center">
      <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
    </div>
    <div>
      <p class="text-sm font-bold text-gray-900">TaskFlow</p>
      <p class="text-xs text-gray-400 truncate max-w-[140px]"><%= current_user.company&.name %></p>
    </div>
  </div>

  <!-- Nav -->
  <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
    <%= render "layouts/nav_item", path: dashboard_index_path, icon: "home", label: "Dashboard" %>
    <%= render "layouts/nav_item", path: tasks_path, icon: "tasks", label: "Tasks" %>

    <% if current_user.manager_or_above? %>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider px-3 pt-5 pb-2">Manage</p>
      <%= render "layouts/nav_item", path: "/team", icon: "users", label: "Team" %>
      <%= render "layouts/nav_item", path: sectors_path, icon: "sectors", label: "Sectors" %>
    <% end %>

    <% if current_user.admin_or_above? %>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider px-3 pt-5 pb-2">Admin</p>
      <%= render "layouts/nav_item", path: admin_root_path, icon: "settings", label: "Admin Panel" %>
    <% end %>
  </nav>

  <!-- User footer -->

    <div class="px-3 py-4 border-t border-gray-100">
  <div style="display:flex;align-items:center;gap:0.75rem;padding:0.5rem 0.75rem;border-radius:0.5rem">
    <%= link_to profile_path, style: "display:flex;align-items:center;gap:0.75rem;flex:1;min-width:0;text-decoration:none" do %>
      <div class="avatar-sm" style="background:#eef2ff;color:#4338ca;display:inline-flex;align-items:center;justify-content:center;border-radius:9999px;font-weight:600;font-size:0.7rem;width:1.75rem;height:1.75rem;flex-shrink:0">
        <%= current_user.initials %>
      </div>
      <div style="flex:1;min-width:0">
        <p style="font-size:0.875rem;font-weight:500;color:#111827;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= current_user.full_name %></p>
        <p style="font-size:0.75rem;color:#9ca3af"><%= current_user.role.humanize %></p>
      </div>
    <% end %>
    <%= button_to destroy_user_session_path,
              method: :delete,
              form: { class: "inline-block m-0 p-0" },
              class: "btn-ghost btn-icon text-gray-400 bg-transparent border-0" do %>
  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
  </svg>
<% end %>
  </div>
</div>
  </div>
</aside>