<div style="max-width:640px;margin:0 auto">
  <div class="page-header">
    <h1 class="page-title">My Profile</h1>
    <%= link_to "Edit Profile", edit_profile_path, class: "btn-secondary" %>
  </div>

  <div class="card" style="margin-bottom:1rem">
    <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem">
      <div class="avatar avatar-lg" style="background:#eef2ff;color:#4338ca;font-size:1.25rem">
        <%= current_user.initials %>
      </div>
      <div>
        <h2 style="font-size:1.125rem;font-weight:600;color:#111827"><%= current_user.full_name %></h2>
        <p style="color:#6b7280;font-size:0.875rem"><%= current_user.email %></p>
        <span class="badge-purple" style="margin-top:0.25rem"><%= current_user.role.humanize %></span>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
      <div>
        <p style="font-size:0.75rem;color:#9ca3af;margin-bottom:0.25rem">Company</p>
        <p style="font-size:0.875rem;color:#374151"><%= current_user.company&.name || "—" %></p>
      </div>
      <div>
        <p style="font-size:0.75rem;color:#9ca3af;margin-bottom:0.25rem">Sector</p>
        <p style="font-size:0.875rem;color:#374151"><%= current_user.sector&.name || "—" %></p>
      </div>
      <div>
        <p style="font-size:0.75rem;color:#9ca3af;margin-bottom:0.25rem">Phone</p>
        <p style="font-size:0.875rem;color:#374151"><%= current_user.phone.presence || "—" %></p>
      </div>
      <div>
        <p style="font-size:0.75rem;color:#9ca3af;margin-bottom:0.25rem">Member since</p>
        <p style="font-size:0.875rem;color:#374151"><%= current_user.created_at.strftime("%B %Y") %></p>
      </div>
    </div>
  </div>
</div>