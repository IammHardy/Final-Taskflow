<div style="max-width:480px;margin:0 auto">
  <div class="page-header">
    <h1 class="page-title">Edit Sector</h1>
    <%= link_to "← Back", sectors_path, class: "btn-secondary" %>
  </div>
  <div class="card">
    <%= form_with model: @sector do |f| %>
      <% if @sector.errors.any? %>
        <div class="flash-alert"><%= @sector.errors.full_messages.first %></div>
      <% end %>
      <div class="form-group">
        <%= f.label :name, class: "label" %>
        <%= f.text_field :name, class: "input" %>
      </div>
      <div class="form-group">
        <%= f.label :description, class: "label" %>
        <%= f.text_area :description, class: "input", rows: 3 %>
      </div>
      <div class="form-group">
        <%= f.label :color, class: "label" %>
        <%= f.color_field :color, class: "input", style: "height:2.5rem;padding:0.25rem" %>
      </div>
      <div style="display:flex;gap:0.75rem;margin-top:1.5rem">
        <%= f.submit "Save Changes", class: "btn-primary" %>
        <%= link_to "Cancel", sectors_path, class: "btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>