<div style="max-width:640px;margin:0 auto">
  <div class="page-header">
    <h1 class="page-title">New Task</h1>
    <%= link_to "← Back", tasks_path, class: "btn-secondary" %>
  </div>
  <div class="card">
    <%= form_with model: @task do |f| %>
      <% if @task.errors.any? %>
        <div class="flash-alert"><%= @task.errors.full_messages.first %></div>
      <% end %>
      <div class="form-group">
        <%= f.label :title, class: "label" %>
        <%= f.text_field :title, class: "input", placeholder: "Task title", autofocus: true %>
      </div>
      <div class="form-group">
        <%= f.label :description, class: "label" %>
        <%= f.text_area :description, class: "input", rows: 4, placeholder: "Describe the task..." %>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
        <div class="form-group">
          <%= f.label :priority, class: "label" %>
          <%= f.select :priority, Task.priorities.keys.map { |p| [p.humanize, p] },
              { selected: "medium" }, { class: "input" } %>
        </div>
        <div class="form-group">
          <%= f.label :status, class: "label" %>
          <%= f.select :status, Task.statuses.keys.map { |s| [s.humanize.gsub("_"," "), s] },
              { selected: "todo" }, { class: "input" } %>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
        <div class="form-group">
          <%= f.label :due_date, class: "label" %>
          <%= f.date_field :due_date, class: "input" %>
        </div>
        <div class="form-group">
          <%= f.label :assignee_id, "Assign to", class: "label" %>
          <%= f.collection_select :assignee_id,
              User.where(company: current_user.company).order(:first_name),
              :id, :full_name,
              { include_blank: "— Unassigned —" }, { class: "input" } %>
        </div>
      </div>
      <div class="form-group">
        <%= f.label :sector_id, "Sector", class: "label" %>
        <%= f.collection_select :sector_id,
            Sector.where(company: current_user.company).order(:name),
            :id, :name,
            { include_blank: "— No sector —" }, { class: "input" } %>
      </div>
      <div style="display:flex;gap:0.75rem;margin-top:1.5rem">
        <%= f.submit "Create Task", class: "btn-primary" %>
        <%= link_to "Cancel", tasks_path, class: "btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>