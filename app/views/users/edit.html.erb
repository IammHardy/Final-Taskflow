<div style="max-width:640px;margin:0 auto">
  <div class="page-header">
    <div>
      <h1 class="page-title">Edit Member</h1>
      <p class="page-subtitle"><%= @user.full_name %></p>
    </div>
    <%= link_to "← Back", users_path, class: "btn-secondary" %>
  </div>

  <div class="card">
    <%= form_with model: @user, local: true do |f| %>

      <% if @user.errors.any? %>
        <div class="flash-alert">
          <%= @user.errors.full_messages.first %>
        </div>
      <% end %>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
        <div class="form-group">
          <%= f.label :first_name, class: "label" %>
          <%= f.text_field :first_name, class: "input" %>
        </div>
        <div class="form-group">
          <%= f.label :last_name, class: "label" %>
          <%= f.text_field :last_name, class: "input" %>
        </div>
      </div>

      <div class="form-group">
        <%= f.label :phone, class: "label" %>
        <%= f.text_field :phone, class: "input", placeholder: "+1 555 000 0000" %>
      </div>

      <div class="form-group">
        <%= f.label :sector_id, "Sector", class: "label" %>
        <%= f.collection_select :sector_id, Sector.all, :id, :name,
            { include_blank: "— No sector —" }, { class: "input" } %>
      </div>

      <% if current_user.admin_or_above? %>
        <div class="form-group">
          <%= f.label :role, class: "label" %>
          <%= f.select :role, User.roles.keys.map { |r| [r.humanize, r] },
              {}, { class: "input" } %>
        </div>

        <div class="form-group" style="display:flex;align-items:center;gap:0.5rem">
          <%= f.check_box :active %>
          <%= f.label :active, "Active account", class: "label", style: "margin:0" %>
        </div>
      <% end %>

      <div style="display:flex;gap:0.75rem;margin-top:1.5rem">
        <%= f.submit "Save Changes", class: "btn-primary" %>
        <%= link_to "Cancel", users_path, class: "btn-secondary" %>
      </div>

    <% end %>
  </div>
</div>